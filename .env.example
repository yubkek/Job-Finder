# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase connection string (pooled - for Next.js API routes)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Supabase direct URL (for Prisma migrations)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── Job Board APIs ───────────────────────────────────────────────────────────
# Adzuna: https://developer.adzuna.com/
ADZUNA_APP_ID="your_adzuna_app_id"
ADZUNA_APP_KEY="your_adzuna_app_key"

# Jooble: https://jooble.org/api/about
JOOBLE_API_KEY="your_jooble_api_key"

# ─── AI Summary ────────────────────────────────────────────────────────────────
# OpenAI API for generating job summaries (uses gpt-4o-mini - cheap & fast)
OPENAI_API_KEY="sk-..."

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Secret token to authenticate the /api/cron/scrape endpoint
CRON_SECRET="your_strong_random_secret_here"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"